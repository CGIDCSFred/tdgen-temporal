# Normalise line endings to LF in the repo; checkout as CRLF on Windows
* text=auto eol=lf

# Force LF for scripts that run on Linux CI
*.py    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.sh    text eol=lf
*.toml  text eol=lf
*.md    text eol=lf

# Windows batch files need CRLF
*.bat   text eol=crlf

# Binaries
*.pptx  binary
*.db    binary
